---
import MuxVideo from "../../lib/components/MuxVideo.svelte";
import type { WorkEntry } from "../../lib/astro/site-content";

interface Props {
	works: WorkEntry[];
	title?: string;
	kicker?: string;
	maxCount?: number | null;
}

const {
	works,
	title = "LIVE EMBEDDED WORKS",
	kicker = "Actual miniature surfaces, not decorative thumbnails.",
	maxCount = null,
} = Astro.props;
const displayWorks = typeof maxCount === "number" ? works.slice(0, maxCount) : works;
---

<section class="embedded-works" data-testid="live-embedded-works">
	<header class="embedded-works__header">
		<p class="embedded-works__eyebrow">{title}</p>
		<h2>{kicker}</h2>
	</header>

	<div class="embedded-works__grid">
		{displayWorks.map((work) => (
			<article class="embed-card" style={`--work-accent: ${work.accent}; --work-surface: ${work.surface};`}>
				<div class="embed-card__frame">
					{
						work.previewSurface?.type === "internal" && work.previewSurface.href ? (
							<iframe src={work.previewSurface.href} title={`${work.title} interactive surface`} loading="lazy"></iframe>
						) : work.previewSurface?.type === "mux" && work.previewSurface.playbackId ? (
							<MuxVideo
								client:load
								playbackId={work.previewSurface.playbackId}
								title={work.title}
								poster={work.previewSurface.poster}
							/>
						) : work.previewSurface?.type === "video" && work.previewSurface.src ? (
							<video
								src={work.previewSurface.src}
								poster={work.previewSurface.poster}
								muted
								playsinline
								loop
								autoplay
								controls={false}
							></video>
						) : work.previewSurface?.type === "static" && work.previewSurface.src ? (
							<img src={work.previewSurface.src} alt={`${work.title} preview`} loading="lazy" />
						) : (
							<iframe
								src={work.previewSurface?.href ?? `/embed/${work.slug}`}
								title={`${work.title} live embed`}
								loading="lazy"
							></iframe>
						)
					}
				</div>

				<div class="embed-card__copy">
					<p class="embed-card__meta">{work.year} · {work.client} · {work.status}</p>
					<h3>{work.title}</h3>
					<p>{work.summary}</p>
					<div class="embed-card__stack">
						<span class="embed-card__surface">{work.previewSurface?.label ?? "Live surface"}</span>
						{work.stack.slice(0, 3).map((item) => (
							<span>{item}</span>
						))}
					</div>
					<div class="embed-card__links">
						{work.internalRoute && (
							<a href={work.internalRoute.href}>
								{work.internalRoute.label}
							</a>
						)}
						{!work.internalRoute && work.primaryAction && (
							<a
								href={work.primaryAction.href}
								target={work.primaryAction.external ? "_blank" : undefined}
								rel={work.primaryAction.external ? "noopener noreferrer" : undefined}
							>
								{work.primaryAction.label}
								{work.primaryAction.external ? " ↗" : ""}
							</a>
						)}
						{work.externalLink && work.externalLink.href !== work.primaryAction?.href && (
							<a href={work.externalLink.href} target="_blank" rel="noopener noreferrer">
								{work.externalLink.label} ↗
							</a>
						)}
					</div>
				</div>
			</article>
		))}
	</div>
</section>

<style>
	.embedded-works {
		display: grid;
		gap: 1rem;
	}

	.embedded-works__header {
		display: grid;
		gap: 0.4rem;
		max-width: 46rem;
	}

	.embedded-works__eyebrow,
	.embed-card__meta {
		margin: 0;
		font-family: var(--font-mono);
		font-size: 0.72rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--color-text-subtle);
	}

	.embedded-works__header h2,
	.embed-card__copy h3 {
		margin: 0;
		font-family: var(--font-display);
		letter-spacing: -0.05em;
	}

	.embedded-works__header h2 {
		font-size: clamp(1.8rem, 3vw, 2.6rem);
		line-height: 0.98;
	}

	.embedded-works__grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
		gap: 1rem;
	}

	.embed-card {
		display: grid;
		gap: 0.9rem;
		padding: 1rem;
		border: 1px solid color-mix(in srgb, var(--work-accent) 18%, var(--border-color));
		background: color-mix(in srgb, var(--work-surface) 32%, var(--color-surface) 68%);
		transition:
			transform var(--duration-fast) var(--easing),
			border-color var(--duration-fast) var(--easing),
			background-color var(--duration-fast) var(--easing);
	}

	.embed-card:hover {
		transform: translateY(-2px);
		border-color: color-mix(in srgb, var(--work-accent) 34%, var(--border-color));
		background: color-mix(in srgb, var(--work-surface) 40%, var(--color-surface) 60%);
	}

	.embed-card__frame {
		position: relative;
		aspect-ratio: 16 / 10;
		overflow: hidden;
		border: 1px solid var(--border-color);
		background: var(--color-surface);
		box-shadow: var(--shadow-sm);
	}

	.embed-card iframe {
		width: 100%;
		height: 100%;
		border: 0;
		background: #f4efe7;
	}

	.embed-card img,
	.embed-card video {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		background: #f4efe7;
	}

	.embed-card__copy {
		display: grid;
		gap: 0.45rem;
	}

	.embed-card__copy p {
		margin: 0;
		line-height: 1.58;
		color: var(--color-text-secondary);
	}

	.embed-card__stack {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
	}

	.embed-card__stack span {
		padding: 0.32rem 0.5rem;
		border: 1px solid var(--border-color);
		font-family: var(--font-mono);
		font-size: 0.72rem;
		color: var(--color-text-subtle);
		background: color-mix(in srgb, var(--color-surface) 85%, transparent);
	}

	.embed-card__surface {
		color: var(--color-text);
	}

	.embed-card__copy a {
		color: var(--color-text);
		text-decoration: none;
		width: fit-content;
		font-family: var(--font-mono);
		font-size: 0.74rem;
	}

	.embed-card__links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem 1rem;
	}
</style>
