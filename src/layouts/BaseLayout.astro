---
import "../app.css";
import DisableDraftMode from "../components/DisableDraftMode.tsx";
import PublicNav from "../components/public/PublicNav.svelte";
import PublicRuntimeSync from "../components/public/PublicRuntimeSync.svelte";
import PublicWipBanner from "../components/public/PublicWipBanner.svelte";
import MobileDock from "../components/public/MobileDock.svelte";
import SanityVisualEditing from "../components/SanityVisualEditing.tsx";
import { buildEditorialHref, getPreviewDocumentLabel } from "../lib/astro/preview";
import { fallbackSiteConfig, homepageFallbackSlice } from "../lib/astro/site-content";
import { layoutConfig } from "../lib/data/layout-config";
import ThemeSwitcher from "../lib/components/ThemeSwitcher.svelte";
import FontSwitcher from "../lib/components/FontSwitcher.svelte";
import { fallbackConnections, fallbackNavItems } from "../lib/astro/site-content";
import type { PublicRuntimeState } from "../lib/server/convex";
import { getSanityPreviewState } from "../lib/server/sanity-preview";

interface NavItem {
	pageId?: string;
	label: string;
	route: string;
	navOrder?: number;
	archived?: boolean;
}

interface Props {
	title?: string;
	description?: string;
	navItems?: NavItem[];
	activePath?: string;
	previewLabel?: string;
	previewDocument?: string;
	robots?: string;
	runtime?: PublicRuntimeState;
}

const {
	title = "Stüssy Senik",
	description = "Portfolio of Stüssy Senik: creative technologist, design engineer, and interactive systems builder.",
	navItems = fallbackNavItems,
	activePath = "/",
	previewLabel = "Editorial preview",
	previewDocument = "heroContent",
	robots = "index, follow",
	runtime,
} = Astro.props;

const previewHref = `/admin/content?document=${previewDocument}`;
const previewEditHref = buildEditorialHref(previewDocument);
const previewDocumentLabel = getPreviewDocumentLabel(previewDocument);
const previewState = getSanityPreviewState(Astro);
const runtimeNavItems = runtime?.navItems?.length ? runtime.navItems : navItems;
const resolvedNavItems = runtimeNavItems.filter((item) => item.route && !item.route.startsWith("/admin"));
const siteConfig = (runtime?.siteConfig ?? fallbackSiteConfig) as PublicRuntimeState["siteConfig"];
const featureFlags = runtime?.featureFlags ?? [];
const wipBannerEnabled =
	featureFlags.find((flag) => flag.key === "wip-banner")?.enabled ?? layoutConfig.showWipBanner;
const initialRuntime = {
	navItems: resolvedNavItems,
	siteConfig,
	featureFlags,
} satisfies PublicRuntimeState;
const footerEdition = runtime?.siteConfig?.footerEdition ?? fallbackSiteConfig.footerEdition;
const footerYear = runtime?.siteConfig?.footerYear ?? new Date().getFullYear();
const siteMode = siteConfig.mode ?? "multi-page";
const navMode = siteConfig.navMode ?? "sidebar";
const showPreviewChrome = previewState.previewEnabled;
const publicWipBannerEnabled = showPreviewChrome ? wipBannerEnabled : false;
const shellSummary = homepageFallbackSlice.summary;
---

<!doctype html>
<html
	lang="en"
	data-theme="minimal"
	data-font="public"
	data-preview-mode={previewState.previewEnabled ? "on" : "off"}
	data-draft-mode={previewState.draftModeEnabled ? "on" : "off"}
	data-site-mode={siteMode}
	data-nav-mode={navMode}
>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="robots" content={robots} />
	</head>
	<body data-theme="minimal" data-font="public" data-site-mode={siteMode} data-nav-mode={navMode}>
		<script is:inline>
			const params = new URLSearchParams(window.location.search);
			const previewFromUrl = params.get("preview") === "1";
			if (previewFromUrl) {
				document.documentElement.dataset.previewMode = "on";
			}
			const savedTheme = localStorage.getItem("theme");
			const savedFont = localStorage.getItem("preferred-font");
			const normalizedTheme =
				savedTheme === "paper" ? "minimal" : savedTheme === "accessible" || savedTheme === "sumi" ? "bw" : savedTheme;
			document.documentElement.dataset.theme = normalizedTheme || document.body.dataset.theme || "minimal";
			document.body.dataset.theme = document.documentElement.dataset.theme;
			document.documentElement.dataset.font = savedFont || document.body.dataset.font || "public";
			document.body.dataset.font = document.documentElement.dataset.font;
			document.documentElement.dataset.siteMode = document.body.dataset.siteMode || "multi-page";
			document.documentElement.dataset.navMode = document.body.dataset.navMode || "sidebar";
		</script>

			<div class="astro-shell">
				<PublicRuntimeSync client:load initialRuntime={initialRuntime} />
			<aside class="astro-shell__sidebar" data-testid="site-header">
				<div class="astro-shell__sidebar-top">
					<a href="/" class="astro-shell__wordmark astro-shell__wordmark--sidebar">Stüssy Senik</a>
					<p class="astro-shell__sidebar-summary">{shellSummary}</p>
					<div class="astro-shell__route-chip">
						<span>Edition</span>
						<strong>{siteMode === "one-page" ? "Public deck" : "Portfolio system"}</strong>
					</div>
				</div>

				<div class="astro-shell__sidebar-groups">
					<div class="astro-shell__group">
						<p class="astro-shell__group-label">NAVIGATION</p>
						<PublicNav client:load items={resolvedNavItems} activePath={activePath} />
					</div>

					<div class="astro-shell__group" style="margin-top: 1rem;">
						<p class="astro-shell__group-label">CONNECTIONS</p>
						<div class="astro-shell__connections astro-shell__connections--sidebar">
							{fallbackConnections.map((item) => (
								<a href={item.url} target={item.url.startsWith("mailto:") ? undefined : "_blank"} rel="noreferrer noopener">
									{item.label} ↗
								</a>
							))}
						</div>
					</div>
				</div>

				<div class="astro-shell__sidebar-status">
					<span class="astro-shell__availability">
						<span class="astro-terminal__dot"></span>
						available
					</span>
				</div>
			</aside>

			<MobileDock client:load navItems={resolvedNavItems} activePath={activePath} />

			<main class="astro-shell__main">
				{publicWipBannerEnabled && (
					<PublicWipBanner client:load enabled={publicWipBannerEnabled} message={layoutConfig.wipBannerMessage} />
				)}

				{showPreviewChrome && (
					<div class="astro-shell__preview" data-testid="preview-ribbon">
						<div>
							<p class="astro-shell__preview-label">Preview mode</p>
							<strong>{previewLabel}</strong>
						</div>
						<p>Review the actual public route, then jump back into the editorial lane without switching systems.</p>
						<div class="astro-shell__preview-actions">
							<a href={previewHref}>Open `/admin/content`</a>
							<a href={previewEditHref}>Edit {previewDocumentLabel}</a>
						</div>
					</div>
				)}
				<slot />
			</main>

			<footer class="astro-terminal">
				<div class="astro-terminal__left">
					<span class="astro-terminal__pill astro-terminal__pill--edition">{footerEdition} · {footerYear}</span>
					<span class="astro-terminal__pill astro-terminal__pill--path">{activePath}</span>
					<span class="astro-terminal__pill astro-terminal__status astro-terminal__status--mobile-hidden">
						<span class="astro-terminal__dot"></span>
						available
					</span>
				</div>

				<div class="astro-terminal__controls">
					<ThemeSwitcher client:load />
					<FontSwitcher client:load />
					<span class="astro-terminal__heart" aria-hidden="true">♥</span>
				</div>
			</footer>
		</div>

		{previewState.visualEditingEnabled && (
			<>
				<SanityVisualEditing client:only="react" />
				<DisableDraftMode client:only="react" />
			</>
		)}
	</body>
</html>

<style>
	:global(body) {
		margin: 0;
		background: color-mix(in srgb, var(--color-bg) 94%, #f0ece4 6%);
		color: var(--color-text);
	}

	.astro-shell {
		min-height: 100vh;
		--sidebar-width: clamp(15.5rem, 16vw, 19rem);
		--shell-gutter: clamp(1.25rem, 3vw, 3rem);
		--content-stage-max: 124rem;
		--shell-edge: calc(var(--sidebar-width) + var(--shell-gutter));
		position: relative;
		overflow-x: clip;
	}

	.astro-shell::before {
		content: "";
		display: none;
	}

	.astro-shell__sidebar {
		display: none;
	}

	.astro-shell__main {
		position: relative;
		z-index: 1;
		width: 100%;
		max-width: 100%;
		padding: 1rem 1rem 7rem;
		margin-right: auto;
	}

	.astro-terminal {
		display: none;
	}

	@media (min-width: 900px) {
		.astro-shell::before {
			display: block;
			position: fixed;
			inset: 0;
			pointer-events: none;
			z-index: 0;
			background:
				linear-gradient(
					to right,
					transparent 0,
					transparent calc(var(--shell-edge) - 1px),
					color-mix(in srgb, var(--border-color) 72%, transparent) calc(var(--shell-edge) - 1px),
					color-mix(in srgb, var(--border-color) 72%, transparent) var(--shell-edge),
					transparent var(--shell-edge)
				);
		}

		.astro-shell__sidebar {
			display: flex;
			position: fixed;
			top: 0;
			left: 0;
			bottom: 0;
			width: var(--sidebar-width);
			padding: clamp(1.75rem, 3vh, 3rem) var(--shell-gutter);
			background: color-mix(in srgb, var(--color-bg) 96%, white 4%);
			flex-direction: column;
			gap: clamp(2.25rem, 4vh, 3.5rem);
			overflow-y: auto;
			border-right: 1px solid var(--border-color);
		}

		.astro-shell__main {
			margin-left: var(--sidebar-width);
			width: min(var(--content-stage-max), calc(100vw - var(--sidebar-width) - (var(--shell-gutter) * 2)));
			max-width: calc(100vw - var(--sidebar-width) - (var(--shell-gutter) * 2));
			padding: clamp(2rem, 5vh, 4rem) var(--shell-gutter) 12rem;
		}

		.astro-terminal {
			display: flex;
			position: fixed;
			right: var(--shell-gutter);
			bottom: 2rem;
			width: fit-content;
			max-width: min(64rem, calc(100vw - var(--sidebar-width) - (var(--shell-gutter) * 2)));
			justify-content: space-between;
			align-items: center;
			gap: 0.9rem;
			padding: 0.7rem 0.8rem;
			border: 1px solid color-mix(in srgb, var(--border-color-strong) 82%, transparent);
			background: color-mix(in srgb, var(--color-surface) 94%, var(--color-bg-alt));
			font-family: var(--font-mono);
			font-size: 0.74rem;
			z-index: 40;
			backdrop-filter: blur(10px);
			box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
		}
	}

	.astro-shell__sidebar-top {
		display: grid;
		gap: 0.9rem;
	}

	.astro-shell__sidebar-groups {
		display: grid;
		gap: 2.5rem;
	}

	.astro-shell__main {
		position: relative;
		z-index: 1;
		width: 100%;
		max-width: 100%;
		padding: 1rem 1rem 7rem;
		margin-right: auto;
		overflow-x: clip;
	}

	.astro-shell__eyebrow,
	.astro-shell__route-chip span,
	.astro-shell__command-hints {
		font-family: var(--font-mono);
		font-size: 0.7rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--color-text-subtle);
	}

	.astro-shell__path-label {
		color: var(--color-text-subtle);
	}

	.astro-shell__availability {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		color: var(--color-success);
	}

	.astro-shell__mobile-path,
	.astro-shell__sidebar-summary {
		margin: 0;
		font-size: 0.86rem;
		line-height: 1.55;
		color: var(--color-text-secondary);
	}

	.astro-shell__route-chip {
		display: grid;
		gap: 0.2rem;
		padding: 0.8rem 0.9rem;
		border: 1px solid color-mix(in srgb, var(--border-color) 85%, transparent);
		background: color-mix(in srgb, var(--color-surface) 86%, transparent);
	}

	.astro-shell__route-chip strong {
		font-family: var(--font-mono);
		font-size: 0.77rem;
		font-weight: 500;
		color: var(--color-text);
	}

	.astro-shell__command-hints {
		display: flex;
		flex-wrap: wrap;
		gap: 0.55rem;
	}

	:global(html[data-preview-mode="on"] .astro-shell__preview) {
		display: grid;
	}

	:global(.draft-mode-exit) {
		position: fixed;
		right: 1rem;
		bottom: 1rem;
		z-index: 1200;
		padding: 0.8rem 1rem;
		border-radius: 999px;
		background: var(--color-text);
		color: var(--color-bg);
		text-decoration: none;
		box-shadow: var(--shadow-lg);
	}

	.astro-shell__preview p,
	.astro-shell__preview strong,
	.astro-shell__group-label {
		margin: 0;
	}

	.astro-shell__preview-label {
		font-size: 0.72rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--color-text-subtle);
	}

	.astro-shell__preview {
		display: none;
		grid-template-columns: auto minmax(0, 1fr) auto;
		gap: 1rem;
		align-items: center;
		padding: 1rem 1.05rem;
		margin-bottom: 1rem;
		border: 1px solid var(--border-color);
		background: color-mix(in srgb, var(--color-surface) 92%, var(--color-accent-subtle));
		color: var(--color-text);
	}

	.astro-shell__preview a {
		color: inherit;
		text-decoration: none;
		padding: 0.72rem 0.9rem;
		border: 1px solid var(--border-color);
		background: color-mix(in srgb, var(--color-surface) 86%, transparent);
	}

	.astro-shell__preview-actions {
		display: inline-flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		justify-content: flex-end;
	}

	.astro-shell__group {
		display: grid;
		gap: 0.5rem;
	}

	.astro-shell__wordmark {
		font-family: var(--font-display);
		color: inherit;
		text-decoration: none;
		font-weight: 800;
		letter-spacing: -0.06em;
		line-height: 0.9;
	}

	.astro-shell__wordmark--sidebar {
		font-size: clamp(2.2rem, 2rem + 0.9vw, 3.25rem);
		display: block;
		margin-bottom: 0.5rem;
	}

	.astro-shell__group-label {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		color: var(--color-text-subtle);
		margin-bottom: 1.25rem;
		opacity: 0.8;
	}

	.astro-shell__connections--sidebar {
		display: grid;
		gap: 0.9rem;
	}

	.astro-shell__connections--sidebar a {
		font-family: var(--font-mono);
		font-size: 0.9rem;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		color: var(--color-text-subtle);
		text-decoration: none;
		transition: color var(--duration-fast) var(--easing);
	}

	.astro-shell__connections--sidebar a:hover {
		color: var(--color-text);
	}

	.astro-shell__sidebar-status {
		margin-top: auto;
		display: flex;
		align-items: center;
		gap: 0.8rem;
		font-family: var(--font-mono);
		font-size: 0.85rem;
		padding-top: 1rem;
		border-top: 1px solid color-mix(in srgb, var(--border-color) 80%, transparent);
	}

	.astro-shell__availability {
		display: inline-flex;
		align-items: center;
		gap: 0.65rem;
		color: var(--color-success);
		text-transform: lowercase;
		font-weight: 500;
	}

	.astro-terminal__dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: var(--color-success);
		box-shadow: 0 0 10px var(--color-success);
	}

	.astro-terminal__left,
	.astro-terminal__controls {
		display: flex;
		align-items: center;
		gap: 0.55rem;
		min-width: 0;
		flex-wrap: wrap;
	}

	.astro-terminal__pill {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		padding: 0.45rem 0.72rem;
		border: 1px solid color-mix(in srgb, var(--border-color) 80%, transparent);
		background: color-mix(in srgb, var(--color-bg) 45%, transparent);
		white-space: nowrap;
	}

	.astro-terminal__pill--edition {
		color: var(--color-text-subtle);
		max-width: 24rem;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.astro-terminal__pill--path {
		color: var(--color-text-secondary);
	}

	.astro-terminal__status {
		color: var(--color-success);
	}

	.astro-terminal__dot {
		width: 0.45rem;
		height: 0.45rem;
		border-radius: 999px;
		background: currentColor;
	}

	.astro-terminal__heart {
		font-size: 0.8rem;
		color: #ef4444;
		user-select: none;
		opacity: 0.8;
	}

	.astro-terminal__hint {
		color: var(--color-text-subtle);
		padding-left: 0.2rem;
	}

	.astro-shell__preview {
		grid-template-columns: 1fr;
	}

	.astro-shell__preview-actions {
		justify-content: flex-start;
	}

	@media (min-width: 900px) {
		.astro-shell__preview {
			grid-template-columns: auto minmax(0, 1fr) auto;
		}

		.astro-shell__preview-actions {
			justify-content: flex-end;
		}
	}
</style>
