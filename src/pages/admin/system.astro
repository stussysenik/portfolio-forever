---
import AdminPreviewDeck from "../../components/admin/AdminPreviewDeck.astro";
import AdminLayout from "../../layouts/AdminLayout.astro";
import AdminSystemApp from "../../lib/astro/AdminSystemApp.svelte";
import HistoryAudit from "../../lib/admin/HistoryAudit.svelte";
import { previewTargets } from "../../lib/astro/site-content";

const systemPreviewTargets = previewTargets.filter((target) =>
	["/", "/works", "/process", "/cv"].includes(target.route),
);
---

<AdminLayout title="Admin | System" active="system">
	<section class="system-grid">
		<section class="system-copy">
			<p class="system-copy__eyebrow">System lane</p>
			<h2>Convex remains the live layer, but the public shell stays authoritative.</h2>
			<p>
				Runtime flags, page visibility, and shared state live here. The important constraint is that those controls
				still govern the same route model and token system the public portfolio renders.
			</p>
		</section>

		<div class="system-history">
			<HistoryAudit client:only="svelte" />
		</div>
	</section>

	<div class="system-runtime">
		<AdminSystemApp client:only="svelte" />
	</div>

	<AdminPreviewDeck
		items={systemPreviewTargets}
		title="Public routes governed by this lane"
		description="The system lane matters only if it remains visibly tied to the same Astro routes people actually browse."
	/>
</AdminLayout>

<style>
	.system-grid {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(24rem, 0.9fr);
		gap: var(--space-md);
		margin-bottom: var(--space-lg);
	}

	.system-copy {
		display: grid;
		gap: var(--space-sm);
		padding: var(--space-md);
		border: 1px solid var(--border-color);
		background: color-mix(in srgb, var(--color-surface) 88%, var(--color-bg-alt));
	}

	.system-copy__eyebrow {
		margin: 0;
		font-family: var(--font-mono);
		font-size: 0.72rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--color-text-subtle);
	}

	.system-copy h2 {
		margin: 0;
		font-family: var(--font-display);
		font-size: clamp(1.8rem, 3vw, 2.8rem);
		line-height: 0.96;
		letter-spacing: var(--letter-spacing-tight);
	}

	.system-copy p {
		margin: 0;
		line-height: 1.62;
		color: var(--color-text-secondary);
	}

	.system-history {
		display: grid;
		align-content: start;
	}

	.system-runtime {
		margin-bottom: var(--space-lg);
		border: 1px solid var(--border-color);
		background: color-mix(in srgb, var(--color-surface) 90%, var(--color-bg-alt));
		overflow: hidden;
	}

	@media (max-width: 920px) {
		.system-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
