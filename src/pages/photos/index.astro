---
import BaseLayout from "../../layouts/BaseLayout.astro";
import MediaGrid from "../../lib/components/media/MediaGrid.svelte";
import SectionShell from "../../lib/components/layout/SectionShell.svelte";
import { getPublicRuntimeState } from "../../lib/server/convex";
import { createConvexHttpClient } from "../../lib/convex";
import { api } from "../../../convex/_generated/api";

const client = createConvexHttpClient();
const [runtime, collections] = await Promise.all([
	getPublicRuntimeState(),
	client.query(api.photoCollections.getVisible)
]);
---

<BaseLayout
	title="Photography | Stüssy Senik"
	description="Photo collections, archival scans, and digital captures."
	activePath="/photos"
	runtime={runtime}
>
	<SectionShell title="PHOTOS" subtitle="Photography collections & archival scans">
		<div class="collections-grid">
			{collections.map((c) => (
				<a href={`/photos/${c.slug}`} class="collection-card">
					<div class="cover-image">
						{c.coverAsset && (
							<img src={c.coverAsset.url} alt={c.title} loading="lazy" />
						)}
					</div>
					<div class="info">
						<h3>{c.title}</h3>
						{c.description && <p>{c.description}</p>}
					</div>
				</a>
			))}
		</div>
	</SectionShell>
</BaseLayout>

<style>
	.collections-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
		gap: 3rem;
		padding: 2rem 0;
	}

	.collection-card {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		text-decoration: none;
		color: inherit;
		transition: transform 0.2s ease;
	}

	.collection-card:hover {
		transform: translateY(-4px);
	}

	.cover-image {
		aspect-ratio: 3/2;
		background: var(--color-bg-secondary);
		border-radius: 4px;
		overflow: hidden;
	}

	.cover-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.info h3 {
		font-family: var(--font-display);
		font-size: 1.5rem;
		margin: 0;
		text-transform: uppercase;
		letter-spacing: -0.02em;
	}

	.info p {
		font-size: 0.9rem;
		color: var(--color-text-secondary);
		margin: 0.5rem 0 0 0;
		line-height: 1.5;
	}
</style>
