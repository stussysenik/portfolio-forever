---
import BaseLayout from "../layouts/BaseLayout.astro";
import HirePage from "../lib/components/hire/HirePage.svelte";
import { getPublicRuntimeState } from "../lib/server/convex";

const runtime = await getPublicRuntimeState();
---

<BaseLayout
	title="Hire Stüssy Senik | Design Engineer"
	description="Direct hiring proof for 30+ roles across Ramp, Linear, OpenAI, DeepMind, Notion, Apple, Mistral AI, and more."
	activePath="/hire"
	runtime={runtime}
	robots="index, follow"
>
	<HirePage client:load />
</BaseLayout>
