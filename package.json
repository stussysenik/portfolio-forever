{
        "name": "portfolio-2026",
        "private": true,
        "version": "0.0.1",
        "packageManager": "bun@latest",
        "type": "module",
        "scripts": {
                "dev": "astro dev --host 127.0.0.1 --port 4321",
                "build": "astro build",
                "preview": "astro preview",
                "prepare": "astro sync",
                "check": "astro check --tsconfig tsconfig.astro.json",
                "check:watch": "astro check --watch",
                "dev:sveltekit": "bun scripts/portless-shim.js portfolio vite dev",
                "build:sveltekit": "vite build",
                "preview:sveltekit": "vite preview",
                "test": "playwright test",
                "test:unit": "vitest run --config vitest.config.ts",
                "test:unit:watch": "vitest",
                "test:jest": "jest --config jest.config.ts --runInBand",
                "test:cypress": "cypress run",
                "test:ui": "playwright test --ui",
                "test:headed": "playwright test --headed",
                "test:debug": "playwright test --debug",
                "test:report": "playwright show-report",
                "test:install": "playwright install --with-deps chromium firefox webkit",
                "quota:init": "bun scripts/claude-quota-ledger.ts init",
                "quota:doctor": "bun scripts/claude-quota-ledger.ts doctor",
                "quota:probe": "bun scripts/claude-quota-ledger.ts probe",
                "quota:report": "bun scripts/claude-quota-ledger.ts report",
                "quota:install": "bun scripts/claude-quota-ledger.ts install-launchd",
                "quota:uninstall": "bun scripts/claude-quota-ledger.ts uninstall-launchd",
                "sync": "astro sync",
                "sync:sveltekit": "svelte-kit sync || echo ''",
                "capture-previews": "bun scripts/capture-previews.ts",
                "record-previews": "bun scripts/record-previews.ts",
                "session:init": "bun scripts/session.ts init",
                "session:log": "bun scripts/session.ts log",
                "storybook": "storybook dev -p 6006",
                "build-storybook": "storybook build",
                "clj:compile": "find src/lib/clj -name '*.cljs' -exec npx squint compile {} --output-dir src/lib/clj --paths src/lib/clj \\;",
                "clj:watch": "npx squint watch --config squint.edn"
        },
