{
        "name": "portfolio-2026",
        "private": true,
        "version": "0.0.1",
        "packageManager": "bun@latest",
        "type": "module",
        "scripts": {
                "dev": "bun scripts/portless-shim.js portfolio vite dev",
                "build": "vite build",
                "preview": "vite preview",
                "prepare": "svelte-kit sync || echo ''",
                "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
                "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
                "test": "playwright test",
                "test:unit": "vitest run",
                "test:unit:watch": "vitest",
                "test:jest": "jest --config jest.config.ts",
                "test:cypress": "cypress run",
                "test:ui": "playwright test --ui",
                "test:headed": "playwright test --headed",
                "test:debug": "playwright test --debug",
                "test:report": "playwright show-report",
                "test:install": "playwright install --with-deps chromium firefox webkit",
                "quota:init": "bun scripts/claude-quota-ledger.ts init",
                "quota:doctor": "bun scripts/claude-quota-ledger.ts doctor",
                "quota:probe": "bun scripts/claude-quota-ledger.ts probe",
                "quota:report": "bun scripts/claude-quota-ledger.ts report",
                "quota:install": "bun scripts/claude-quota-ledger.ts install-launchd",
                "quota:uninstall": "bun scripts/claude-quota-ledger.ts uninstall-launchd",
                "sync": "svelte-kit sync || echo ''",
                "capture-previews": "bun scripts/capture-previews.ts",
                "record-previews": "bun scripts/record-previews.ts",
                "storybook": "storybook dev -p 6006",
                "build-storybook": "storybook build",
                "clj:compile": "find src/lib/clj -name '*.cljs' -exec npx squint compile {} --output-dir src/lib/clj --paths src/lib/clj \\;",
                "clj:watch": "npx squint watch --config squint.edn"
        },
        "devDependencies": {
                "@axe-core/playwright": "^4.11.2",
                "@iconify-json/lucide": "^1.2.102",
                "@playwright/test": "^1.59.1",
                "@sentry/sveltekit": "^10.49.0",
                "@storybook/addon-a11y": "^10.3.5",
                "@storybook/addon-essentials": "^8.6.14",
                "@storybook/svelte-vite": "^10.3.5",
                "@sveltejs/adapter-auto": "^7.0.1",
                "@sveltejs/adapter-static": "^3.0.10",
                "@sveltejs/kit": "^2.57.1",
                "@sveltejs/vite-plugin-svelte": "^6.2.4",
                "@types/katex": "^0.16.8",
                "axe-core": "^4.11.3",
                "chromatic": "^16.3.0",
                "cypress": "^15.14.0",
                "happy-dom": "^20.9.0",
                "jest-environment-jsdom": "^30.3.0",
                "playwright": "^1.59.1",
                "squint-cljs": "^0.11.187",
                "storybook": "^10.3.5",
                "svelte": "^5.55.4",
                "svelte-check": "^4.4.6",
                "typescript": "^5.9.3",
                "unplugin-icons": "^23.0.1",
                "vite": "^7.3.2",
                "vitest": "^4.1.4"
        },
        "dependencies": {
                "@clerk/clerk-js": "^6.7.4",
                "@iconify-json/ph": "^1.2.2",
                "@melt-ui/svelte": "^0.86.6",
                "@mux/mux-player": "^3.11.8",
                "convex": "^1.35.1",
                "esbuild": "^0.28.0",
                "fengari-web": "^0.1.4",
                "katex": "^0.16.45",
                "posthog-js": "^1.369.3",
                "vercel": "^51.7.0",
                "zod": "^4.3.6"
        }
}
