{
        "name": "portfolio-2026",
        "private": true,
        "version": "0.0.1",
        "packageManager": "bun@latest",
        "type": "module",
        "scripts": {
                "dev": "portless portfolio vite dev",
                "build": "vite build",
                "preview": "vite preview",
                "prepare": "svelte-kit sync || echo ''",
                "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
                "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
                "test": "playwright test",
                "test:unit": "vitest run",
                "test:unit:watch": "vitest",
                "test:ui": "playwright test --ui",
                "test:headed": "playwright test --headed",
                "test:debug": "playwright test --debug",
                "test:report": "playwright show-report",
                "test:install": "playwright install --with-deps chromium firefox webkit",
                "quota:init": "bun scripts/claude-quota-ledger.ts init",
                "quota:doctor": "bun scripts/claude-quota-ledger.ts doctor",
                "quota:probe": "bun scripts/claude-quota-ledger.ts probe",
                "quota:report": "bun scripts/claude-quota-ledger.ts report",
                "quota:install": "bun scripts/claude-quota-ledger.ts install-launchd",
                "quota:uninstall": "bun scripts/claude-quota-ledger.ts uninstall-launchd",
                "sync": "svelte-kit sync || echo ''",
                "capture-previews": "bun scripts/capture-previews.ts",
                "record-previews": "bun scripts/record-previews.ts",
                "storybook": "storybook dev -p 6006",
                "build-storybook": "storybook build"
        },
        "devDependencies": {
                "@axe-core/playwright": "^4.11.0",
                "@playwright/test": "^1.57.0",
                "@sentry/sveltekit": "^10.46.0",
                "@storybook/addon-a11y": "^10.3.3",
                "@storybook/addon-essentials": "^8.6.14",
                "@storybook/svelte-vite": "^10.3.3",
                "@sveltejs/adapter-auto": "^7.0.0",
                "@sveltejs/adapter-static": "^3.0.10",
                "@sveltejs/kit": "^2.49.1",
                "@sveltejs/vite-plugin-svelte": "^6.2.1",
                "axe-core": "^4.11.1",
                "chromatic": "^16.0.0",
                "playwright": "^1.57.0",
                "storybook": "^10.3.3",
                "svelte": "^5.45.6",
                "svelte-check": "^4.3.4",
                "typescript": "^5.9.3",
                "vite": "^7.2.6",
                "vitest": "^4.1.2"
        },
        "dependencies": {
                "@clerk/clerk-js": "^6.3.3",
                "@mux/mux-player": "^3.11.7",
                "convex": "^1.34.1",
                "fengari-web": "^0.1.4",
                "posthog-js": "^1.364.1"
        }
}
